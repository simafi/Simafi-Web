# Copiar a `.env.supabase_prod` en la raíz del repo (simafiweb/.env.supabase_prod)
# NO subir este archivo al repositorio.
#
# IMPORTANTE: este modo es para probar localmente apuntando a Supabase PROD.
# No correr migraciones automáticamente.

DJANGO_ENV=supabase_prod
DJANGO_DEBUG=1
DJANGO_LOCAL_HTTP=1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# Mapas Simafi: crear tablas en esta BD (equiv. migrate catastro 0020_mapas_simafi):
#   cd backend
#   python catastro/scripts/apply_mapas_sql.py
# o  .\crear_tablas_mapas_supabase.ps1
# O pegar en Supabase -> SQL Editor el archivo: backend/catastro/sql/mapas_simafi_supabase.sql

