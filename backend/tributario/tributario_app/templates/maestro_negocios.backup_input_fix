{% load static %}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Gestión de Negocios</title>
    <!-- Font Awesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Leaflet CSS for maps -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <!-- Configuración del cursor de IA en español -->
    <script src="{% static 'js/cursor_ai_config.js' %}"></script>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f0f5ff 0%, #e6f7ff 100%);
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            color: #333;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        header {
            text-align: center;
            padding: 30px 0;
            background: linear-gradient(90deg, #1e88e5 0%, #0d47a1 100%);
            border-radius: 12px;
            color: white;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
            position: relative;
            overflow: hidden;
        }
        header:before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23ffffff" fill-opacity="0.1" d="M0,96L48,112C96,128,192,160,288,186.7C384,213,480,235,576,213.3C672,192,768,128,864,128C960,128,1056,192,1152,208C1248,224,1344,192,1392,176L1440,160L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>');
            background-size: cover;
            background-position: center;
        }
        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            font-weight: 600;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
            position: relative;
        }
        .subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            max-width: 800px;
            margin: 0 auto;
            position: relative;
        }
        .card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            padding: 30px;
            margin-bottom: 30px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
        }
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-width: 120px;
            justify-content: center;
        }
        .btn-success {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
        }
        .btn-success:hover {
            background: linear-gradient(135deg, #218838 0%, #1ea085 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }
        .btn-primary {
            background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
            color: white;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #0056b3 0%, #004085 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
        }
        .btn-secondary {
            background: linear-gradient(135deg, #6c757d 0%, #545b62 100%);
            color: white;
        }
        .btn-secondary:hover {
            background: linear-gradient(135deg, #545b62 0%, #3d444a 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.3);
        }
        .btn-danger {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            color: white;
        }
        .btn-danger:hover {
            background: linear-gradient(135deg, #c82333 0%, #a71e2a 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

        .form-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem 2.2rem;
            align-items: flex-start;
        }

        .form-group {
            background: #f8fafc;
            border-radius: 13px;
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.06);
            padding: 1.1rem 1rem 0.7rem 1rem;
            margin-bottom: 0;
            border: 1px solid #e5e7eb;
            transition: box-shadow 0.18s;
            flex: 1 1 auto;
            min-width: 200px;
        }

        /* Clases para diferentes tamaños de campos */
        .form-group-small {
            flex: 0 1 150px;
            min-width: 150px;
        }

        .form-group-medium {
            flex: 1 1 250px;
            min-width: 200px;
        }

        .form-group-large {
            flex: 2 1 350px;
            min-width: 300px;
        }

        .form-group-xlarge {
            flex: 3 1 500px;
            min-width: 400px;
        }

        /* Clases específicas para campos con ancho fijo */
        .form-group-municipio {
            flex: 0 1 140px;
            min-width: 140px;
            max-width: 140px;
        }
        
        .form-group-municipio input[readonly] {
            background-color: #f8f9fa !important;
            color: #6c757d !important;
            cursor: not-allowed;
        }
        
        .form-group-rtm {
            flex: 0 1 220px;
            min-width: 220px;
            max-width: 220px;
        }

        .form-group-expediente {
            flex: 0 1 160px;
            min-width: 160px;
            max-width: 160px;
        }

        .form-group-fecha {
            flex: 0 1 200px;
            min-width: 200px;
            max-width: 200px;
        }

        .form-group-rtn-negocio {
            flex: 0 1 180px;
            min-width: 180px;
            max-width: 180px;
        }

        .form-group-rtn-negocio-specific {
            flex: 0 1 220px;
            min-width: 220px;
            max-width: 220px;
        }

        .form-group-catastral-specific {
            flex: 0 1 210px;
            min-width: 210px;
            max-width: 210px;
        }

        .form-group-coordenada-specific {
            flex: 0 1 180px;
            min-width: 180px;
            max-width: 180px;
        }
        
        .form-group-coordenada-x-specific {
            flex: 0 1 220px;
            min-width: 220px;
            max-width: 220px;
        }

        .form-group-id_identidadrep-specific {
            flex: 0 1 220px;
            min-width: 220px;
            max-width: 220px;
        }

        .form-group-nombre-negocio-specific {
            flex: 0 1 450px;
            min-width: 450px;
            max-width: 450px;
        }

        .form-group-telefono-specific {
            flex: 0 1 140px;
            min-width: 140px;
            max-width: 140px;
        }

        .form-group-celular-specific {
            flex: 0 1 140px;
            min-width: 140px;
            max-width: 140px;
        }

        .form-group:focus-within {
            box-shadow: 0 4px 16px rgba(37, 99, 235, 0.13);
            border-color: #2563eb;
        }

        .form-group-full {
            grid-column: 1 / -1;
        }

        label {
            display: block;
            margin-bottom: 0.35rem;
            color: #374151;
            font-weight: 600;
            font-size: 1.02rem;
            letter-spacing: 0.2px;
        }

        input[type="text"],
        input[type="number"],
        input[type="date"],
        input[type="email"],
        textarea,
        select {
            width: 100%;
            padding: 0.7rem 0.8rem;
            border: 1.2px solid #d1d5db;
            border-radius: 7px;
            font-size: 1.05rem;
            background: #fff;
            transition: border 0.2s, box-shadow 0.2s;
            box-shadow: 0 1px 3px rgba(30, 41, 59, 0.04);
        }

        input[type="text"]:focus,
        input[type="number"]:focus,
        input[type="date"]:focus,
        input[type="email"]:focus,
        textarea:focus,
        select:focus {
            border-color: #2563eb;
            outline: none;
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.09);
        }

        textarea {
            min-height: 60px;
        }

        .btn-group {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
            margin-top: 2.2rem;
            justify-content: space-between;
        }

        button {
            flex: 1 1 30%;
            padding: 1rem;
            border: none;
            border-radius: 8px;
            font-size: 1.07rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            min-width: 140px;
        }

        /* Map Styles */
        .map-container {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            padding: 20px;
            margin-bottom: 30px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .map-container:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
        }

        .map-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #e5e7eb;
        }

        .map-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #374151;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .map-controls {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .map-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .map-btn-primary {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            color: white;
        }

        .map-btn-primary:hover {
            background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 100%);
            transform: translateY(-1px);
        }

        .map-btn-secondary {
            background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
            color: white;
        }

        .map-btn-secondary:hover {
            background: linear-gradient(135deg, #4b5563 0%, #374151 100%);
            transform: translateY(-1px);
        }

        #map {
            height: 400px;
            width: 100%;
            border-radius: 8px;
            border: 2px solid #e5e7eb;
        }

        .coordinates-info {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 15px;
            margin-top: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .coordinate-display {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
        }

        .coordinate-value {
            background: #fff;
            padding: 5px 10px;
            border-radius: 4px;
            border: 1px solid #d1d5db;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
            color: #374151;
        }
        
        .coordinate-value-x {
            background: #fff;
            padding: 5px 10px;
            border-radius: 4px;
            border: 1px solid #d1d5db;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
            color: #374151;
            min-width: 140px;
            width: 140px;
        }

        .map-instructions {
            background: #e0f2fe;
            border: 1px solid #0288d1;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 15px;
            font-size: 0.9rem;
            color: #0277bd;
        }

        .map-instructions i {
            margin-right: 8px;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .map-controls {
                flex-direction: column;
                align-items: stretch;
            }
            
            .coordinates-info {
                flex-direction: column;
                align-items: stretch;
            }
            
            .coordinate-display {
                justify-content: space-between;
            }
            
            .form-group-municipio {
                flex: 1 1 100%;
                min-width: 100%;
                max-width: 100%;
            }
            
            .form-group-coordenada-x-specific {
                flex: 1 1 100%;
                min-width: 100%;
                max-width: 100%;
            }
            
            .coordinate-value-x {
                min-width: 100%;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1><i class="fas fa-store"></i> Gestión de Negocios</h1>
            <p class="subtitle">Sistema de administración y control de negocios</p>
        </header>

        <div class="card">
            <form method="post" novalidate>
                {% csrf_token %}
                <div class="form-grid">
                    <!-- Primera línea -->
                    <div class="form-group form-group-municipio">
                        <label for="id_empre">Municipio <span style="color:#e11d48">*</span></label>
                        <input type="text" id="id_empre" name="empre" maxlength="4" required readonly
                               value="{{ municipio_codigo|default:negocio.empre|default_if_none:'' }}" 
                               style="background-color: #f8f9fa; color: #6c757d;">
                    </div>
                    <div class="form-group form-group-rtm">
                        <label for="id_rtm">RTM <span style="color:#e11d48">*</span></label>
                        <input type="text" id="id_rtm" name="rtm" maxlength="16" required 
                               style="text-transform: uppercase;"
                               value="{{ negocio.rtm|default_if_none:'' }}" 
                               oninput="this.value = this.value.toUpperCase()"
                               placeholder="Ingrese RTM">
                    </div>
                    <div class="form-group form-group-expediente">
                        <label for="id_expe">Expediente <span style="color:#e11d48">*</span></label>
                        <input type="text" id="id_expe" name="expe" maxlength="12" required 
                               style="text-transform: uppercase;"
                               value="{{ negocio.expe|default_if_none:'' }}" 
                               oninput="this.value = this.value.toUpperCase()"
                               placeholder="Ingrese Expediente">
                    </div>
                    <div class="form-group form-group-fecha">
                        <label for="id_fecha_ini">Fecha Inicio</label>
                        <input type="date" id="id_fecha_ini" name="fecha_ini"
                               value="{{ negocio.fecha_ini|date:'Y-m-d'|default_if_none:'' }}">
                    </div>
                    <div class="form-group form-group-fecha">
                        <label for="id_fecha_can">Fecha Cancelación</label>
                        <input type="date" id="id_fecha_can" name="fecha_can"
                               value="{{ negocio.fecha_can|date:'Y-m-d'|default_if_none:'' }}">
                    </div>

                    <!-- Segunda línea -->
                            <div class="form-group form-group-id_identidadrep-specific">
            <label for="id_identidad">DNI</label>
            <input type="text" id="id_identidad" name="identidad" maxlength="20"
                   value="{{ negocio.identidad|default_if_none:'' }}">
                    </div>
                    <div class="form-group form-group-rtn-negocio-specific">
                        <label for="id_rtnpersonal">RTN Personal</label>
                        <input type="text" id="id_rtnpersonal" name="rtnpersonal" maxlength="20"
                               value="{{ negocio.rtnpersonal|default_if_none:'' }}">
                    </div>
                    <div class="form-group" style="flex: 2 1 450px; min-width: 450px;">
                        <label for="id_comerciante">Comerciante</label>
                        <input type="text" id="id_comerciante" name="comerciante" maxlength="100"
                               value="{{ negocio.comerciante|default_if_none:'' }}">
                    </div>

                    <!-- Tercera línea -->
                    <div class="form-group form-group-rtn-negocio-specific">
                        <label for="id_rtnnego">RTN Negocio</label>
                        <input type="text" id="id_rtnnego" name="rtnnego" maxlength="19"
                               value="{{ negocio.rtnnego|default_if_none:'' }}">
                    </div>
                    <div class="form-group form-group-nombre-negocio-specific">
                        <label for="id_nombrenego">Nombre del Negocio</label>
                        <input type="text" id="id_nombrenego" name="nombrenego" maxlength="100"
                               value="{{ negocio.nombrenego|default_if_none:'' }}">
                    </div>
                    <div class="form-group form-group-large">
                        <label for="id_actividad">Actividad Económica <span style="color:#e11d48">*</span> <small style="color: #6c757d; font-size: 0.85rem;">(Filtradas por municipio: {{ municipio_codigo }})</small></label>
                        <select id="id_actividad" name="actividad" required>
                            <option value="">Seleccione una actividad económica</option>
                    {% for act in actividades %}
                        <option value="{{ act.codigo }}" {% if negocio.actividad == act.codigo %}selected{% endif %}>
                            {{ act.codigo }} - {{ act.descripcion }}
                        </option>
                    {% endfor %}
                </select>
            </div>


                    <!-- Cuarta línea -->
                            <div class="form-group form-group-id_identidadrep-specific">
            <label for="id_identidadrep">DNI Representante</label>
            <input type="text" id="id_identidadrep" name="identidadrep" maxlength="20"
                   value="{{ negocio.identidadrep|default_if_none:'' }}">
                    </div>
                    <div class="form-group" style="flex: 2 1 450px; min-width: 450px;">
                        <label for="id_representante">Representante</label>
                        <input type="text" id="id_representante" name="representante" maxlength="100"
                               value="{{ negocio.representante|default_if_none:'' }}">
                    </div>
                    <div class="form-group form-group-small">
                        <label for="id_estatus">Estado</label>
                        <select id="id_estatus" name="estatus">
                            <option value="A" {% if negocio.estatus == "A" %}selected{% endif %}>Activo</option>
                            <option value="I" {% if negocio.estatus == "I" %}selected{% endif %}>Inactivo</option>
                        </select>
                    </div>

                    <!-- Quinta línea -->
            <div class="form-group form-group-catastral-specific">
                <label for="id_catastral">Catastral</label>
                <input type="text" id="id_catastral" name="catastral" maxlength="19" style="text-transform: uppercase;"
                       value="{{ negocio.catastral|default_if_none:'' }}" oninput="this.value = this.value.toUpperCase()">
            </div>
            <div class="form-group form-group-coordenada-x-specific">
                <label for="id_cx">Coordenada X</label>
                <input type="number" id="id_cx" name="cx" step="0.0000001" min="-999.9999999" max="999.9999999"
                       value="{{ negocio.cx|default_if_none:'0.0000000' }}">
            </div>
            <div class="form-group form-group-coordenada-specific">
                <label for="id_cy">Coordenada Y</label>
                <input type="number" id="id_cy" name="cy" step="0.0000001" min="-999.9999999" max="999.9999999"
                       value="{{ negocio.cy|default_if_none:'0.0000000' }}">
            </div>
            <div class="form-group form-group-large">
                <label for="id_direccion">Dirección</label>
                <input type="text" id="id_direccion" name="direccion" maxlength="100"
                       value="{{ negocio.direccion|default_if_none:'' }}">
            </div>
            <div class="form-group form-group-large">
                <label for="id_correo">Correo</label>
                <input type="email" id="id_correo" name="correo" maxlength="35"
                       value="{{ negocio.correo|default_if_none:'' }}">
            </div>
            <div class="form-group form-group-large">
                <label for="id_pagweb">Página Web</label>
                <input type="text" id="id_pagweb" name="pagweb" maxlength="40"
                       value="{{ negocio.pagweb|default_if_none:'' }}">
            </div>

            <!-- Sexta línea: Solo Socios -->
            <div class="form-group" style="flex: 1 1 100%; min-width: 100%;">
                <label for="id_socios">Socios</label>
                <input type="text" id="id_socios" name="socios" maxlength="250"
                       value="{{ negocio.socios|default_if_none:'' }}">
            </div>
            <div class="form-group" style="flex: 1 1 100%; min-width: 100%;">
                <label for="id_comentario">Comentario</label>
                <textarea id="id_comentario" name="comentario"
                          maxlength="15000">{{ negocio.comentario|default_if_none:'' }}</textarea>
            </div>
        </div>

        <!-- Map Navigation Section -->
        <div class="map-container">
            <div class="map-header">
                <div class="map-title">
                    <i class="fas fa-map-marker-alt"></i>
                    Navegación en Mapa
                </div>
                <div class="map-controls">
                    <button type="button" class="map-btn map-btn-primary" onclick="centerOnHonduras()">
                        <i class="fas fa-crosshairs"></i> Centrar en Honduras
                    </button>
                    <button type="button" class="map-btn map-btn-secondary" onclick="clearCoordinates()">
                        <i class="fas fa-eraser"></i> Limpiar Coordenadas
                    </button>
                    <button type="button" class="map-btn map-btn-secondary" onclick="getCurrentLocation()">
                        <i class="fas fa-location-arrow"></i> Mi Ubicación
                    </button>
                </div>
            </div>
            
            <div class="map-instructions">
                <i class="fas fa-info-circle"></i>
                <strong>Instrucciones:</strong> Haz clic en el mapa para establecer las coordenadas del negocio. 
                Las coordenadas se actualizarán automáticamente en los campos X e Y.
            </div>
            
            <div id="map"></div>
            
            <div class="coordinates-info">
                <div class="coordinate-display">
                    <i class="fas fa-map-pin"></i>
                    <span>Coordenada X:</span>
                    <span class="coordinate-value-x" id="display-cx">{{ negocio.cx|default_if_none:'0.0000000' }}</span>
                </div>
                <div class="coordinate-display">
                    <i class="fas fa-map-pin"></i>
                    <span>Coordenada Y:</span>
                    <span class="coordinate-value" id="display-cy">{{ negocio.cy|default_if_none:'0.0000000' }}</span>
                </div>
                <div class="coordinate-display">
                    <i class="fas fa-info-circle"></i>
                    <span>Estado:</span>
                    <span class="coordinate-value" id="coordinate-status">Listo para seleccionar</span>
                </div>
            </div>
        </div>

        <div class="btn-group" style="text-align: center; margin-top: 30px;">
            <button type="submit" name="accion" value="nuevo" class="btn btn-success">
                <i class="fas fa-plus"></i> Nuevo
            </button>
            <button type="submit" name="accion" value="salvar" class="btn btn-primary">
