                debugMensaje('Por favor, complete el campo RTM', false);
                return false;
            }
            
            if (!expeValue || expeValue === '') {
                console.log('❌ Campo Expediente faltante');
                debugMensaje('Por favor, complete el campo Expediente', false);
                return false;
            }
            
            console.log('✅ Todos los campos obligatorios están completos');
            return true;
        }
        
        // Función para manejar botones de manera modular
        function manejarBoton(botonValue, event) {
            console.log(`🔄 Procesando botón: ${botonValue}`);
            console.log(`🔍 Tipo de evento: ${event.type}`);
            console.log(`🔍 Evento submitter:`, event.submitter);
            
            const config = BOTONES_CONFIG[botonValue];
            if (!config) {
                console.log(`ℹ️ Botón no configurado: ${botonValue} - Permitiendo envío normal`);
                return true; // Permitir envío normal
            }
            
            console.log(`✅ Configuración encontrada para ${botonValue}: ${config.descripcion}`);
            console.log(`🔍 Tipo de botón: ${config.tipo}`);
            console.log(`🔍 Requiere validación: ${config.requiereValidacion}`);
            console.log(`🔍 Handler: ${config.handler}`);
            
            // Validar campos si es requerido (solo para botones que no son salvar)
            if (config.requiereValidacion && botonValue !== 'salvar') {
                console.log('🔍 Validando campos obligatorios...');
                if (!validarCamposObligatorios()) {
                    console.log('❌ Validación falló, previniendo envío');
                    event.preventDefault();
                    return false;
                }
                console.log('✅ Validación exitosa');
            }
            
            // Manejar botones especiales
            if (config.tipo === 'especial') {
                console.log('🔍 Botón especial detectado, previniendo envío normal');
                event.preventDefault();
                
                if (config.handler === 'handleSalvarSubmit') {
                    console.log('🔄 Llamando a handleSalvarSubmit');
                    try {
                        handleSalvarSubmit();
                        console.log('✅ handleSalvarSubmit ejecutado correctamente');
                    } catch (error) {
                        console.error('❌ Error al ejecutar handleSalvarSubmit:', error);
                    }
                } else if (config.handler === 'handleEliminarSubmit') {
                    console.log('🔄 Llamando a handleEliminarSubmit');
                    try {
                        handleEliminarSubmit();
                        console.log('✅ handleEliminarSubmit ejecutado correctamente');
                    } catch (error) {
                        console.error('❌ Error al ejecutar handleEliminarSubmit:', error);
                    }
                }
                return false;
            }
            
            // Para botones normales, permitir envío normal
            console.log(`ℹ️ Botón normal: ${botonValue} - Permitiendo envío normal`);
            return true;
        }
        
