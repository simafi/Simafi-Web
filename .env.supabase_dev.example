# Copiar a `.env.supabase_dev` en la raíz del repo (simafiweb/.env.supabase_dev)
# NO subir este archivo al repositorio.

DJANGO_ENV=supabase_dev
DJANGO_DEBUG=1
DJANGO_LOCAL_HTTP=1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Usa una sola URL (para correr local pero apuntando a Supabase dev)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

