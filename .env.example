# Copiar a `.env` en la raíz del repo (simafiweb/.env) y ajustar valores.
# NO subir `.env` al repositorio.

# --- Entorno Django ---
DJANGO_DEBUG=1
# En producción: generar con `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`
DJANGO_SECRET_KEY=
# Lista separada por comas, sin espacios problemáticos:
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tu-dominio.gob.hn

# HTTPS / CSRF (obligatorio con DEBUG=0 y dominio público)
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.gob.hn
# Pruebas con ngrok (HTTPS): si el login falla por CSRF, añade el origen exacto:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://xxxx.ngrok-free.dev
# Si Nginx ya fuerza HTTPS, puede ponerse 0 para evitar doble redirección
# DJANGO_SECURE_SSL_REDIRECT=1

# --- PostgreSQL ---
DJANGO_DB_NAME=bdsimafi
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=TU_PASSWORD
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432

# Alternativa recomendada (Supabase / Vercel Postgres): URL completa.
# Ejemplos de variables soportadas por `settings.py`: DATABASE_URL, POSTGRES_URL, DJANGO_DATABASE_URL.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Vercel: correr migraciones en build (además de VERCEL_ENV=production).
# DJANGO_RUN_MIGRATIONS=1

# --- Archivos subidos (VPS: ruta absoluta persistente) ---
# DJANGO_MEDIA_ROOT=/var/lib/simafi/media
# DJANGO_MEDIA_URL=/media/

# --- Correo (producción) ---
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=noreply@tu-dominio.gob.hn
